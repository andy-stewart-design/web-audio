{
  "lexicon": 1,
  "id": "live.drome.follow",
  "defs": {
    "main": {
      "type": "record",
      "description": "A follow relationship between two Drome users.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "string",
            "format": "did",
            "description": "DID of the user being followed."
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
