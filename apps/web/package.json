{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"lex:build": "lex build --lexicons ../../lexicons --out src/lib/lexicons --importExt '' --indexFile --override"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.6",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@atproto/common-web": "^0.4.21",
		"@atproto/lex": "^0.0.25",
		"@atproto/oauth-client": "0.6.1",
		"@atproto/oauth-client-node": "^0.3.17",
		"@floating-ui/dom": "^1.7.6",
		"@neondatabase/serverless": "^1.1.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@web-audio/audio-engine": "workspace:*",
		"@web-audio/clock": "workspace:*",
		"@web-audio/context": "workspace:*",
		"@web-audio/editor": "workspace:*",
		"@web-audio/fluid": "workspace:*",
		"@web-audio/schema": "workspace:*",
		"@web-audio/tokens": "workspace:*"
	}
}
